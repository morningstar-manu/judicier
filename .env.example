# Turso (LibSQL) — requis pour la persistance partagée en production
TURSO_DATABASE_URL=libsql://votre-base-nom-utilisateur.turso.io
TURSO_AUTH_TOKEN=votre_token_turso

# Requis pour l'API v1 — signature des tokens d'authentification (JWT-like)
GESTIPERS_API_SECRET=changez-moi-avec-une-valeur-secrete-longue-et-aleatoire

# Développement local : forcer IndexedDB au lieu de l'API Turso
# VITE_STORAGE=local

# URL publique de l'app (QR codes des cartes — scan vers vérification automatique)
VITE_APP_URL=https://www.gestipers.org
